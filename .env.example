# Copy to .env (gitignored). create_trace_nsis_installer.ps1 loads this into the
# process environment, and build.ps1 honors these as overrides so no machine-specific
# or secret config needs to live in the tracked repo.
#
# vcpkg location. If unset, build.ps1 falls back to $env:VCPKG_ROOT, then to the
# bundled ./vcpkg submodule (git submodule update --init vcpkg).
TRACE_VCPKG_PATH=

# Optional config overrides (env var > settings.json > default)
TRACE_SENTRY_DSN=
TRACE_SIGN_SUBJECT_NAME=
TRACE_VS_VERSION_MIN=
TRACE_VS_VERSION_MAX=
TRACE_VCPKG_PLATFORM_TOOLSET=

# Read directly by build.ps1 when present (not via the override map above)
AMPLITUDE_API_KEY=
